# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Port ranges for incoming SRT streams
INCOMING_PORT_START=5000
INCOMING_PORT_END=5020

# Port ranges for outgoing SRT streams
OUTGOING_PORT_START=7000
OUTGOING_PORT_END=7100

# Max concurrent incoming streams
MAX_INCOMING_STREAMS=10

# Paths
LOGS_DIR=/opt/srt-bot/logs
STATE_FILE=/opt/srt-bot/data/state.json

# Public IP or domain
SERVER_PUBLIC_IP=your-domain.org

# Admin Telegram user ID (get from @userinfobot)
ADMIN_USER_ID=

# Multi-server config (JSON array)
# Each server: id, name, host, domain, ssh_user, ssh_key_path, incoming_port_start/end, outgoing_port_start/end
# Example with 2 servers (SPB + MSK):
SERVERS_CONFIG='[{"id": "spb", "name": "Санкт-Петербург", "host": "1.2.3.4", "domain": "spb.example.org", "ssh_user": "root", "ssh_key_path": "/root/.ssh/id_rsa", "incoming_port_start": 5000, "incoming_port_end": 5020, "outgoing_port_start": 7000, "outgoing_port_end": 7100}, {"id": "msk", "name": "Москва", "host": "5.6.7.8", "domain": "msk.example.org", "ssh_user": "root", "ssh_key_path": "/root/.ssh/id_rsa", "incoming_port_start": 4000, "incoming_port_end": 4020, "outgoing_port_start": 6000, "outgoing_port_end": 6100}]'
